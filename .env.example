# Sanity ─ create a free project at https://www.sanity.io/manage
# then copy these into a local .env.local file with your real values.
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# Optional: server-only token for authenticated/draft reads & writes.
# Create under Project → API → Tokens (Viewer or Editor).
SANITY_API_READ_TOKEN=""
